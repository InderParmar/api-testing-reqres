        {
          "name": "POST create user - dynamic data",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique test data so this request can run repeatedly",
                  "//without hitting uniqueness constraint error_details",
                  "",
                  "const timestamp = Date.now();",
                  "",
                  "//Unique email - timestamp ensures it's never the same twice",
                  "const uniqueEmail = `testuser_${timestamp}@reqres.in`;",
                  "",
                  "// Random job from a realistic list",
                  "const jobs = [\"Engineer\", \"Designer\", \"Manager\", \"Analyst\", \"Developer\"];",
                  "const randomJob = jobs[Math.floor(Math.random() * jobs.length)];",
                  "",
                  "// Random first name",
                  "const firstNames = [\"Alice\", \"Bob\", \"Charlie\", \"Diana\", \"Eve\", \"Frank\"];",
                  "const randomName = firstNames[Math.floor(Math.random() * firstNames.length)];",
                  "",
                  "// Save all values to environment",
                  "pm.environment.set(\"dynamic_email\", uniqueEmail);",
                  "pm.environment.set(\"dynamic_job\",randomJob);",
                  "pm.environment.set(\"dynamic_name\", randomName);",
                  "",
                  "// Log what was created",
                  "console.log(`Pre-request: Creating user with:`);",
                  "console.log(` name: ${randomName}`);",
                  "console.log(` email: ${uniqueEmail}`);",
                  "console.log(` email: ${randomJob}`);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 - user created\", () =>",
                  "{",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response time under 2000ms\", () =>",
                  "{",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"Response contains created user id\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"id\");",
                  "    pm.expect(body.id).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"Response contains timestamp\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"createdAt\");",
                  "})",
                  "",
                  "pm.test(\"Created user name matches sent name\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    const sent_username = pm.environment.get(\"dynamic_name\");",
                  "    pm.expect(body.name).to.be.eql(sent_username);",
                  "});",
                  "",
                  "pm.test(\"Created user email matches sent email\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    const sent_email = pm.environment.get(\"dynamic_email\");",
                  "    pm.expect(body.email).to.be.eql(sent_email);",
                  "});",
                  "",
                  "pm.test(\"Created user job matches sent job\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    const sent_job = pm.environment.get(\"dynamic_job\");",
                  "    pm.expect(body.job).to.be.eql(sent_job);",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
