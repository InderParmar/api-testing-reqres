                  "if(!token || token === \"\" || token === null)",
                  "{",
                  "    console.warn(\"WARNING: token environment variable is empty.\");",
                  "    console.warn(\"This request requires authentication.\");",
                  "    console.warn(\"Run 'Post login - valid credentials' first.\");",
