                  "    //EDGE CASE FINDING: page = -1 returns 200 instead of 400",
                  "    // The API silently accepts invalid pagiantion parameters",
                  "    // A more robust API would reurn 400 for invalid page numbers",
                  "    //Reqres falls back to default (page 1) behaviour",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Responsetime is under 2000 ms\", () =>",
                  "{",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "})",
                  "",
                  "pm.test(\"EDGE CASE: negative page returns data - no validation\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    // Server returns data as if page = 1 was requested",
                  "    pm.expect(body).to.have.property(\"data\");",
                  "    pm.expect(body.data).to.be.an(\"array\");",
                  "    console.log('page = -1 returned page number: ' + body.page);",
                  "    console.log('Items returned:'+ body.data.length);",
                  "});",
                  "",
                  "pm.test(\"EDGE CASE: page value in response reveals fallback behaviour\", () =>",
                  "{",
                  "    const body = pm.response.json();",
                  "    // The response tells us what page was actually used",
                  "    // If it returns page 1, the API silently defaulted",
                  "    //Document this: invalid input -> silent default (not ideal)",
                  "    pm.expect(body.page).to.be.a(\"number\");",
                  "    console.log('Requested page: -1, Served page: ' + body.page);",
                  "});"
                ],
